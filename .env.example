# Copy this file to .env.local and fill in your values.
# .env.local is gitignored.

# Google Gemini Developer API key — for the Veo render script
# (web/scripts/render-clip.py). Renders the Veo 2 (silent) and Veo 3 (with
# synced audio) clips for the Briefing Inversion article.
# Get a key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ElevenLabs API key — for the per-page podcast renderer
# (web/scripts/podcasts/_shared/render-podcast.mjs). Voices live in each
# scripts/podcasts/<slug>/voices.json. Get a key at:
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
