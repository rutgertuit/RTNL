# Podcast renderer per-line/per-batch MP3 caches — regenerated by render-podcast.mjs
public/audio/podcasts/**/.lines/
public/audio/podcasts/**/.batches/
# Overlap-mixing intermediates (overlay-reactions.mjs): reaction clips, the
# clean dialogue backup, and the preview. Only the final ep01.mp3 is committed.
public/audio/podcasts/**/.overlay/
public/audio/podcasts/**/ep01.dialogue.mp3
public/audio/podcasts/**/ep01.overlay-preview.mp3
